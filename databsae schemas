CREATE TABLE public.users (
	user_id serial4 NOT NULL,
	user_name varchar(100) NOT NULL,
	email varchar(150) NOT NULL,
	"password" text NOT NULL,
	department_id int4 NULL,
	status varchar(20) DEFAULT 'Active'::character varying NULL,
	join_date date NULL,
	created_at timestamp DEFAULT CURRENT_TIMESTAMP NULL,
	CONSTRAINT users_email_key UNIQUE (email),
	CONSTRAINT users_pkey PRIMARY KEY (user_id),
	CONSTRAINT users_status_check CHECK (((status)::text = ANY (ARRAY[('Active'::character varying)::text, ('Delete'::character varying)::text, ('Inactive'::character varying)::text]))),
	CONSTRAINT users_department_id_fkey FOREIGN KEY (department_id) REFERENCES public.departments(department_id)
);


-- public.device_requests definition

