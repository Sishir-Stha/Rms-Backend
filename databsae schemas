CREATE TABLE public.device_requests (
	request_id serial4 NOT NULL,
	requested_by int4 NULL,
	department_id int4 NULL,
	device_type varchar(100) NULL,
	brand varchar(150) NULL,
	reason text NULL,
	quantity int4 DEFAULT 1 NULL,
	priority varchar(20) NULL,
	request_date date DEFAULT CURRENT_DATE NULL,
	approval_status varchar(20) NULL,
	approved_by int4 NULL,
	approval_date date NULL,
	created_at timestamp DEFAULT CURRENT_TIMESTAMP NULL,
	updated_at timestamp DEFAULT CURRENT_TIMESTAMP NULL,
	CONSTRAINT device_requests_pkey PRIMARY KEY (request_id),
	CONSTRAINT dr_priority_check CHECK (((priority)::text = ANY (ARRAY[('Low'::character varying)::text, ('Medium'::character varying)::text, ('High'::character varying)::text, ('Critical'::character varying)::text]))),
	CONSTRAINT dr_status_check CHECK (((approval_status)::text = ANY ((ARRAY['Requested'::character varying, 'Pending'::character varying, 'Approved'::character varying, 'Rejected'::character varying])::text[]))),
	CONSTRAINT device_requests_approved_by_fkey FOREIGN KEY (approved_by) REFERENCES public.users(user_id),
	CONSTRAINT device_requests_department_id_fkey FOREIGN KEY (department_id) REFERENCES public.departments(department_id),
	CONSTRAINT device_requests_requested_by_fkey FOREIGN KEY (requested_by) REFERENCES public.users(user_id)
);


