	///// update fucntion reference  /////

	CREATE OR REPLACE FUNCTION public.update_device_request(
    p_request_id      integer,
    p_requested_by    integer  DEFAULT NULL,
    p_department_id   integer  DEFAULT NULL,
    p_device_type     varchar  DEFAULT NULL,
    p_brand           varchar  DEFAULT NULL,
    p_reason          text     DEFAULT NULL,
    p_quantity        integer  DEFAULT NULL,
    p_priority        varchar  DEFAULT NULL,
    p_request_date    date     DEFAULT NULL,
    p_approval_status varchar  DEFAULT NULL,
    p_approved_by     integer  DEFAULT NULL,
    p_approval_date   date     DEFAULT NULL,
    p_kanban_column   varchar  DEFAULT NULL
)
RETURNS boolean
LANGUAGE plpgsql
AS $$
DECLARE
    v_updated_rows INT;
BEGIN
    UPDATE public.device_requests
    SET
        requested_by    = COALESCE(p_requested_by,                      requested_by),
        department_id   = COALESCE(p_department_id,                     department_id),
        device_type     = COALESCE(NULLIF(p_device_type,   ''),         device_type),
        brand           = COALESCE(NULLIF(p_brand,         ''),         brand),
        reason          = COALESCE(NULLIF(p_reason,        ''),         reason),
        quantity        = COALESCE(p_quantity,                          quantity),
        priority        = COALESCE(NULLIF(p_priority,      ''),         priority),
        request_date    = COALESCE(p_request_date,                      request_date),
        approval_status = COALESCE(NULLIF(p_approval_status, ''),       approval_status),
        approved_by     = COALESCE(p_approved_by,                       approved_by),
        approval_date   = COALESCE(p_approval_date,                     approval_date),
        kanban_column   = COALESCE(NULLIF(p_kanban_column, ''),         kanban_column),
        updated_at      = CURRENT_TIMESTAMP
    WHERE request_id = p_request_id;

    GET DIAGNOSTICS v_updated_rows = ROW_COUNT;
    RETURN v_updated_rows > 0;
END;
$$;
